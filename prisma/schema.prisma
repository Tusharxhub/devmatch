// DevMatch v2 - Prisma Schema
// Production-ready schema with proper relations, indexes, and constraints

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Application Models ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  bio           String?   @db.Text
  location      String?
  website       String?
  onlineStatus  Boolean   @default(false)
  lastSeenAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  accounts      Account[]
  sessions      Session[]
  githubProfile GithubProfile?
  skills        UserSkill[]
  intent        UserIntent?

  // Match relations (both directions)
  matchesAsUser   MatchScore[] @relation("MatchUser")
  matchesAsTarget MatchScore[] @relation("MatchTarget")

  // Chat relations
  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")

  @@index([email])
  @@index([onlineStatus])
}

model GithubProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  githubId        Int      @unique
  username        String   @unique
  avatarUrl       String?
  profileUrl      String
  publicRepos     Int      @default(0)
  followers       Int      @default(0)
  following       Int      @default(0)
  totalStars      Int      @default(0)
  totalForks      Int      @default(0)
  contributions   Int      @default(0) // last year
  topLanguages    Json     @default("[]") // [{name, percentage, color}]
  pinnedRepos     Json     @default("[]") // [{name, description, stars, language}]
  activityData    Json     @default("{}") // contribution calendar data
  experienceLevel String   @default("beginner") // beginner, intermediate, advanced, expert
  fetchedAt       DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([username])
  @@index([experienceLevel])
}

model Skill {
  id        String      @id @default(cuid())
  name      String      @unique
  category  String?     // language, framework, tool, platform
  color     String?     // hex color for UI display
  icon      String?     // icon identifier
  createdAt DateTime    @default(now())

  users UserSkill[]

  @@index([category])
}

model UserSkill {
  id          String   @id @default(cuid())
  userId      String
  skillId     String
  proficiency Int      @default(1) // 1-5 scale
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([userId])
  @@index([skillId])
}

model UserIntent {
  id                String   @id @default(cuid())
  userId            String   @unique
  lookingFor        String[] @default([]) // ["collaborator", "mentor", "mentee", "cofounder"]
  projectInterests  String[] @default([]) // ["web", "mobile", "ai", "blockchain", "devops"]
  availableHours    Int      @default(10) // hours per week
  preferredTimezone String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchScore {
  id              String   @id @default(cuid())
  userId          String
  targetUserId    String
  overallScore    Float    // 0-100
  languageScore   Float    @default(0) // common languages weight
  activityScore   Float    @default(0) // activity similarity
  experienceScore Float    @default(0) // experience compatibility
  intentScore     Float    @default(0) // intent compatibility
  reasons         Json     @default("[]") // human readable match reasons
  computedAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User @relation("MatchUser", fields: [userId], references: [id], onDelete: Cascade)
  targetUser User @relation("MatchTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([userId, targetUserId])
  @@index([userId, overallScore(sort: Desc)])
  @@index([targetUserId])
  @@index([overallScore(sort: Desc)])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  content    String   @db.Text
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, read])
  @@index([createdAt(sort: Desc)])
}
